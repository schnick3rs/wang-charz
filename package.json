{
  "name": "doctors-of-doom",
  "version": "7.0.0",
  "engines": {
    "node": "24.x"
  },
  "description": "The Doctors of Doom exist to serve the Wrath and Glory Community",
  "author": "Brother Lucius",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=development nuxt",
    "build": "NODE_OPTIONS=--openssl-legacy-provider nuxt build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "NODE_OPTIONS=--openssl-legacy-provider nuxt start",
    "startProd": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=production node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit",
    "lint": "eslint --ext .js,.ts,.vue .",
    "lint:fix": "eslint --ext .js,.ts,.vue . --fix"
  },
  "dependencies": {
    "@contentful/rich-text-html-renderer": "^16.6.10",
    "@nuxtjs/axios": "^5.13.6",
    "@nuxtjs/pwa": "^3.3.5",
    "@nuxtjs/redirect-module": "^0.3.1",
    "@nuxtjs/sitemap": "^2.4.0",
    "@nuxtjs/vuetify": "^1.12.3",
    "buffer": "^6.0.3",
    "contentful": "^9.3.7",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-promise-router": "^4.1.1",
    "marked": "^4.3.0",
    "nuxt": "^2.18.1",
    "redirect-ssl": "^2.0.1",
    "uuid": "^11.0.3",
    "vue-croppa": "^1.3.8",
    "vue-meta": "^2.4.0",
    "vuex": "^3.6.2",
    "vuex-persist": "^3.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@nuxt/types": "^2.18.1",
    "@nuxt/typescript-build": "^3.0.2",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "nodemon": "^2.0.22",
    "stylus": "^0.64.0",
    "stylus-loader": "^3.0.2",
    "typescript": "^5.9.3"
  }
}
